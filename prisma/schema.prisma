generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  password        String
  role            Role
  phone           String?
  createdAt       DateTime      @default(now())
  cargas          Carga[]       @relation("EmpresaCarga")
  cargasAsignadas Carga[]       @relation("TransportistaAsignado")
  postulaciones     Postulacion[]
  pushSubscriptions PushSubscription[]
}

enum Role {
  EMPRESA
  TRANSPORTISTA
  ADMIN
}

model Carga {
  id                         Int           @id @default(autoincrement())
  titulo                     String
  origen                     String
  destino                    String
  tipoCarga                  String
  peso                       Float?
  volumen                    Float?
  presupuesto                Float?
  fechaCarga                 DateTime
  fechaEntrega               DateTime?
  tiempoEstimado             String?
  descripcion                String?       @db.Text
  contactoNombre             String
  contactoTelefono           String
  contactoEmail              String
  estado                     EstadoCarga   @default(PENDIENTE_PAGO)
  pagado                     Boolean       @default(false)
  mpPaymentId                String?
  transportistaPagoDeadline  DateTime?
  transportistaMpPaymentId   String?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  empresaId                  String
  empresa                    User          @relation("EmpresaCarga", fields: [empresaId], references: [id])
  transportistaAsignadoId    String?
  transportistaAsignado      User?         @relation("TransportistaAsignado", fields: [transportistaAsignadoId], references: [id])
  postulaciones              Postulacion[]
  disputaDescripcion         String?       @db.Text
  disputaAbiertaPor          String?
}

model Postulacion {
  id              Int               @id @default(autoincrement())
  cargaId         Int
  transportistaId String
  mensaje         String?           @db.Text
  estado          EstadoPostulacion @default(PENDIENTE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  carga           Carga             @relation(fields: [cargaId], references: [id])
  transportista   User              @relation(fields: [transportistaId], references: [id])
  vistaTransportista Boolean        @default(false)

  @@unique([cargaId, transportistaId])
}

enum EstadoCarga {
  PENDIENTE_PAGO
  ACTIVA
  PENDIENTE_PAGO_TRANSPORTISTA
  ASIGNADA
  EN_CONFIRMACION
  FINALIZADA
  CANCELADA
  DISPUTA
}

enum EstadoPostulacion {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConfigApp {
  id            Int    @id @default(1)
  comisionTipo  String @default("FIJO")
  comisionValor Float  @default(5000)
}
